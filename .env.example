APP_NAME=VoidRP Account API
API_V1_PREFIX=/api/v1
APP_ENV=development
DEBUG=true

DATABASE_URL=postgresql+psycopg://voidrp:voidrp_password@localhost:5432/voidrp_accounts

JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
EMAIL_TOKEN_EXPIRE_HOURS=24

CORS_ALLOW_ORIGINS=["http://localhost:5173","https://void-rp.ru"]
EMAIL_FROM=noreply@void-rp.ru
EMAIL_BACKEND=logging

PLAY_TICKET_EXPIRE_MINUTES=10
GAME_AUTH_SHARED_SECRET=CHANGE_ME_TO_LONG_RANDOM_SECRET_FOR_GAME_BRIDGE
ADMIN_API_SECRET=CHANGE_ME_TO_LONG_RANDOM_SECRET